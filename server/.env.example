# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local (development):
MONGODB_URI=mongodb://localhost:27017/notes-app

# Atlas (production) — replace placeholders:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/notes-app?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev_secret_change_before_production_abc123xyz789

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
